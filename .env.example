# Environment Configuration
NODE_ENV=development

# MongoDB Connection String
# For local: mongodb://localhost:27017/geoguardian
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/geoguardian?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/geoguardian

# Server Port
PORT=5000

# Auth/JWT
JWT_SECRET=replace-with-a-secure-secret
JWT_EXPIRES_IN=7d

# Seeded master admin credentials
MASTER_ADMIN_EMAIL=admin@gmail.com
MASTER_ADMIN_PASSWORD=admin123

# Allowed frontend origins (comma separated)
CORS_ORIGINS=http://localhost:5173
